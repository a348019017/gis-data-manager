{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GIS Data Manager",
  "version": "0.1.0",
  "identifier": "com.administrator.gis-data-manager",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GIS Data Manager",
        "width": 1100,
        "height": 750,
        "minWidth": 400,
        "minHeight": 800,
        "resizable": true,
        "devtools": true,
        "additionalBrowserArgs": "--remote-debugging-port=9223"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "gis-tray",
      "iconPath": "icons/icon-256.png"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon-256.png",
      "icons/icon.ico"
    ]
  }
}
